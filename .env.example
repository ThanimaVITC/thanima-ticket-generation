# MongoDB Connection
# The app uses MONGODB_URI (no db name in the path) + DATABASE_NAME.
MONGODB_URI=mongodb://localhost:27017
DATABASE_NAME=thanima

# Migration only (used by `npm run migrate-db`, not the running app).
# Source = MONGODB_URI + DATABASE_NAME, target = NEW_MONGODB_URI + NEW_DATABASE_NAME.
# NEW_DATABASE_NAME falls back to DATABASE_NAME if omitted.
# NEW_MONGODB_URI=mongodb+srv://user:pass@new-cluster.example.mongodb.net/?appName=app
# NEW_DATABASE_NAME=

# JWT Secret (change in production!)
JWT_SECRET=thanima-super-secret-key-change-in-production
JWT_EXPIRES_IN=7d

# Redis (optional, for caching)
REDIS_URL=redis://localhost:6379

# QR Code Encryption Key (32 bytes for AES-256, use a secure random string)
QR_ENCRYPTION_KEY=your-32-character-encryption-key

# SMTP Configuration (for sending ticket emails)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=user@example.com
SMTP_PASS=password
SMTP_FROM="Event Team <noreply@example.com>"

# Default Admin Credentials, update this value while seeding the username and passwords
USERNAME_DEF=def_cred
PASSWORD_DEF=def_cred

# Set to True when deploying on Vercel. Caps each email-send request to a maximum
# of 100 emails so the serverless function finishes before the duration timeout.
# Remaining unsent tickets can be sent by triggering the send again.
HOSTING_VERCEL=False

# S3-compatible storage for ticket poster uploads (AWS S3 / Cloudflare R2 /
# DigitalOcean Spaces / MinIO). The bucket is PRIVATE — the browser loads posters
# via short-lived presigned URLs. Required for uploads to work on serverless (Vercel).
S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
S3_REGION=auto
S3_BUCKET=thanima-tickets
S3_ACCESS_KEY_ID=your_access_key_id
S3_SECRET_ACCESS_KEY=your_secret_access_key
# Set to true only for path-style services like MinIO.
S3_FORCE_PATH_STYLE=false
